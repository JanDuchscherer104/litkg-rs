# litgraph-rs local knowledge-graph stack defaults.
# Scripts source `.env` first when present and otherwise fall back to this file.

NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=litgraphlocal
NEO4J_READ_ONLY=false

OLLAMA_BASE_URL=http://localhost:11434/v1
GRAPHITI_LLM_MODEL=gemma3:27b
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIM=1024
GRAPHITI_GROUP_ID=litgraph-docs
SEMAPHORE_LIMIT=2

KG_DATA_ROOT=.data/kg
GRAPHITI_REPO_DIR=.cache/kg/graphiti
CGC_VENV_DIR=.cache/kg/venvs/cgc
